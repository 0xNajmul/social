APP_NAME="Social Automation SaaS"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000
APP_TIMEZONE=UTC

# First-party SPA URL (used in emails / notification links)
FRONTEND_URL=http://localhost:5173
ADMIN_URL=http://localhost:5174

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ---------------------------------------------------------------------------
# Database — PostgreSQL recommended; MySQL and SQLite also supported
# ---------------------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=postflow
DB_USERNAME=root
DB_PASSWORD=

# For SQLite, create the file first:
#   touch database/database.sqlite

# PostgreSQL example:
# DB_CONNECTION=pgsql
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_DATABASE=social_automation
# DB_USERNAME=postgres
# DB_PASSWORD=secret

# MySQL example:
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=social_automation
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database

CACHE_STORE=database

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@postflow.app"
MAIL_FROM_NAME="${APP_NAME}"

# S3-compatible media storage (optional — defaults to public disk)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Sanctum — add your SPA domains in production
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:5173,localhost:5174,127.0.0.1,127.0.0.1:5173,127.0.0.1:5174

# ---------------------------------------------------------------------------
# AI (OpenAI-compatible)
# ---------------------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# ---------------------------------------------------------------------------
# Billing
# ---------------------------------------------------------------------------
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

PADDLE_VENDOR_ID=
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=

# ---------------------------------------------------------------------------
# Social platform OAuth (leave blank for demo mode)
# ---------------------------------------------------------------------------
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_REDIRECT_URI="${APP_URL}/api/oauth/facebook/callback"
# Optional. When set, this Meta configuration must include every FACEBOOK_SCOPES permission.
FACEBOOK_CONFIG_ID=
FACEBOOK_GRAPH_VERSION=v21.0
FACEBOOK_SCOPES=pages_show_list,pages_read_engagement,pages_manage_posts

INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=
INSTAGRAM_REDIRECT_URI="${APP_URL}/api/oauth/instagram/callback"
INSTAGRAM_GRAPH_VERSION=v21.0
INSTAGRAM_SCOPES=instagram_business_basic,instagram_business_content_publish

TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=
TIKTOK_SCOPES=user.info.basic,video.publish

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_LOGIN_CLIENT_ID=
GOOGLE_LOGIN_CLIENT_SECRET=
GOOGLE_LOGIN_REDIRECT_URI="${APP_URL}/api/auth/google/callback"
YOUTUBE_REDIRECT_URI="${APP_URL}/oauth/youtube/callback"

TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
TWITTER_REDIRECT_URI="${APP_URL}/api/oauth/twitter/callback"

LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI="${APP_URL}/api/oauth/linkedin/callback"
LINKEDIN_VERSION=202606
LINKEDIN_PROFILE_SCOPES=openid,profile,email,w_member_social
LINKEDIN_PAGE_SCOPES=openid,profile,email,rw_organization_admin,w_organization_social

PINTEREST_CLIENT_ID=
PINTEREST_CLIENT_SECRET=
PINTEREST_REDIRECT_URI="${APP_URL}/api/oauth/pinterest/callback"
PINTEREST_ACCESS_TOKEN=
PINTEREST_API_BASE=https://api.pinterest.com/v5
PINTEREST_SCOPES=boards:read,pins:read,pins:write,user_accounts:read

REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_REDIRECT_URI="${APP_URL}/api/oauth/reddit/callback"
REDDIT_SCOPES=identity,mysubreddits,read,submit,edit
# Required by Reddit. Replace the username with the Reddit account that owns the app.
REDDIT_USER_AGENT="web:postflow.social-automation:v1.0.0 (by /u/your_reddit_username)"
REDDIT_API_BASE=https://oauth.reddit.com

BLUESKY_PDS_URL=https://bsky.social
BLUESKY_APP_PASSWORD=

MASTODON_INSTANCE_URL=https://mastodon.social
MASTODON_CLIENT_ID=
MASTODON_CLIENT_SECRET=
MASTODON_REDIRECT_URI="${APP_URL}/api/oauth/mastodon/callback"
MASTODON_SCOPES=read:accounts,write:statuses,write:media

TELEGRAM_BOT_TOKEN=
DISCORD_BOT_TOKEN=

# Publishing behaviour
SOCIAL_PUBLISH_RETRIES=3

VITE_APP_NAME="${APP_NAME}"
